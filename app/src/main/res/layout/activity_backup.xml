<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/svPrincipal"
    android:background="@color/backcolor"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="25dp"
        android:layout_marginEnd="25dp">

        <FrameLayout
            android:id="@+id/frame1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/borde_caja_trasparente"
            android:layout_marginTop="50dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginBottom="25dp">

                <TextView
                    android:id="@+id/tvRutaArchivoIn1"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    style="@style/Textos16Negro"
                    android:gravity="start|center"
                    android:text="Archivo de origen..."
                    android:layout_marginStart="20dp"
                    android:layout_marginTop="15dp"
                    android:layout_marginEnd="100dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>

                <ImageView
                    android:id="@+id/ivAbrir"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:src="@drawable/abrir"
                    android:layout_marginTop="25dp"
                    android:layout_marginEnd="20dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <TextView
                    android:id="@+id/tvRutaArchivoIn2"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/fondo_caja_texto"
                    android:gravity="start|center"
                    style="@style/Textos18Negrita"
                    android:layout_marginStart="20dp"
                    android:layout_marginTop="15dp"
                    android:layout_marginEnd="10dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvRutaArchivoIn1"/>

                <Button
                    android:id="@+id/btnImportar"
                    android:layout_width="match_parent"
                    android:layout_height="75dp"
                    style="@style/TextoBotones"
                    android:text="Importar Archivo de Datos..."
                    android:layout_marginStart="10dp"
                    android:layout_marginTop="25dp"
                    android:layout_marginEnd="10dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvRutaArchivoIn2"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </FrameLayout>

        <FrameLayout
            android:id="@+id/frame2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/borde_caja_trasparente"
            android:layout_marginTop="100dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/frame1">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginBottom="25dp">

                <TextView
                    android:id="@+id/tvRutaArchivoOut1"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    style="@style/Textos16Negro"
                    android:gravity="start|center"
                    android:text="Archivo de destino..."
                    android:layout_marginStart="20dp"
                    android:layout_marginTop="15dp"
                    android:layout_marginEnd="100dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>


                <ImageView
                    android:id="@+id/ivGuardar"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:src="@drawable/guardar"
                    android:layout_marginTop="25dp"
                    android:layout_marginEnd="20dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <TextView
                    android:id="@+id/tvRutaArchivoOut2"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/fondo_caja_texto"
                    android:gravity="start|center"
                    style="@style/Textos18Negrita"
                    android:layout_marginStart="20dp"
                    android:layout_marginTop="15dp"
                    android:layout_marginEnd="10dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvRutaArchivoOut1"/>

                <Button
                    android:id="@+id/btnExportar"
                    android:layout_width="match_parent"
                    android:layout_height="75dp"
                    style="@style/TextoBotones"
                    android:text="Exportar Archivo de Datos..."
                    android:layout_marginStart="10dp"
                    android:layout_marginTop="25dp"
                    android:layout_marginEnd="10dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvRutaArchivoOut2"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </FrameLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>


</ScrollView>