<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/svPrincipal"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backcolor">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        tools:context=".ui.excesosjornada.ExcesoJornada">

        <!-- Boton volver -->
        <ImageView
            android:id="@+id/ivVolver"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginTop="25dp"
            android:layout_marginStart="10dp"
            android:src="@drawable/atras3"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>



        <!--Texto Titulo -->
        <TextView
            android:id="@+id/tvTitulo"
            android:layout_width="225dp"
            android:layout_height="35dp"
            android:gravity="start|center"
            android:layout_marginStart="70dp"
            android:layout_marginTop="30dp"
            style="@style/TextosNormales"
            android:text="Resumen Vacaciones..."
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <!--Spinner Anos -->
        <Spinner
            android:id="@+id/spAno"
            android:layout_width="match_parent"
            android:layout_height="35dp"
            style="@style/TextosSp"
            android:layout_marginStart="240dp"
            android:layout_marginTop="30dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <!--Texto tv11 -->
        <TextView
            android:id="@+id/tv11"
            android:layout_width="275dp"
            android:layout_height="35dp"
            android:text="Vacaciones Años Anteriores..."
            android:gravity="start|center"
            style="@style/Textos16Negrita"
            android:layout_marginStart="10dp"
            android:layout_marginTop="30dp"
            app:layout_constraintTop_toBottomOf="@id/tvTitulo"
            app:layout_constraintStart_toStartOf="parent"/>

        <!--Texto tv12 -->
        <androidx.cardview.widget.CardView
            android:layout_width="50dp"
            android:layout_height="35dp"
            app:cardBackgroundColor="@color/primario"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp"
            android:layout_marginEnd="50dp"
            android:layout_marginTop="30dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/spAno">

            <TextView
                android:id="@+id/tv12"
                style="@style/Textos16Negrita"
                android:layout_width="50dp"
                android:layout_height="35dp"
                android:gravity="center"
                android:text="52" >

            </TextView>

        </androidx.cardview.widget.CardView>

        <!--Linea1 -->
        <ImageView
            android:id="@+id/linea1"
            android:layout_width="match_parent"
            android:background="@color/black"
            android:layout_height="1dp"
            android:layout_marginTop="20dp"
            app:layout_constraintEnd_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv11"/>

        <!-- Texto 2 -->
        <TextView
            android:id="@+id/tv2"
            android:layout_width="match_parent"
            android:layout_height="35dp"
            android:gravity="center"
            style="@style/TextosTitulos"
            android:text="Vacaciones disfrutadas este año"
            android:layout_marginStart="10dp"
            android:layout_marginTop="15dp"
            android:layout_marginEnd="10dp"
            app:layout_constraintTop_toBottomOf="@id/linea1"
            app:layout_constraintStart_toStartOf="parent"/>

        <!--Linea2 -->
        <ImageView
            android:id="@+id/linea2"
            android:layout_width="match_parent"
            android:background="@color/black"
            android:layout_height="1dp"
            android:layout_marginTop="15dp"
            app:layout_constraintEnd_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv2"/>

        <!-- ReciclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvVacaciones"
            android:layout_width="match_parent"
            android:layout_height="350dp"
            android:layout_marginTop="40dp"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv2"/>

        <!--Texto tv31 -->
        <TextView
            android:id="@+id/tv31"
            android:layout_width="275dp"
            android:layout_height="25dp"
            android:gravity="start"
            style="@style/Textos20Negrita"
            android:text="Vacaciones Disfrutadas..."
            android:layout_marginStart="10dp"
            android:layout_marginTop="40dp"
            app:layout_constraintTop_toBottomOf="@id/rvVacaciones"
            app:layout_constraintStart_toStartOf="parent"/>

        <!--Texto tv32 -->
        <TextView
            android:id="@+id/tv32"
            android:layout_width="100dp"
            android:layout_height="25dp"
            style="@style/Textos20Negrita"
            android:text="8"
            android:layout_marginTop="40dp"
            android:layout_marginEnd="10dp"
            app:layout_constraintTop_toBottomOf="@id/rvVacaciones"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!--Texto tv41 -->
        <TextView
            android:id="@+id/tv41"
            android:layout_width="275dp"
            android:layout_height="25dp"
            android:gravity="start"
            style="@style/Textos20Negrita"
            android:text="Vacaciones Pendientes..."
            android:layout_marginStart="10dp"
            android:layout_marginTop="30dp"
            app:layout_constraintTop_toBottomOf="@id/tv31"
            app:layout_constraintStart_toStartOf="parent"/>

        <!--Texto tv42 -->
        <TextView
            android:id="@+id/tv42"
            android:layout_width="100dp"
            android:layout_height="25dp"
            style="@style/Textos20Negrita"
            android:text="2"
            android:layout_marginTop="30dp"
            android:layout_marginEnd="10dp"
            app:layout_constraintTop_toBottomOf="@id/tv32"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>


</ScrollView>